generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  logs      Log[]
  favorites Favorite[]
  createdAt DateTime @default(now())
}

model PlaceInfo {
  place_id        String       @id
  name            String?
  address         String?
  lat             Float?
  lng             Float?
  photo_ref       String?
  avg_user_rating Float        @default(0.0)
  rating_count    Int          @default(0)
  override_price  String?
  override_hours  String?
  reviews         UserReview[]
  comments        PlaceComment[]
  favorites       Favorite[]
  updatedAt       DateTime     @updatedAt
}

model PlaceComment {
  id        String   @id @default(uuid())
  place_id  String
  userName  String?
  userEmail String?
  userPhoto String?
  text      String
  imageUrl  String?
  createdAt DateTime @default(now())

  place     PlaceInfo @relation(fields: [place_id], references: [place_id])
}

model Favorite {
  id        String   @id @default(uuid())
  user_email String
  place_id  String
  createdAt DateTime @default(now())

  user      User      @relation(fields: [user_email], references: [email])
  place     PlaceInfo @relation(fields: [place_id], references: [place_id])

  @@unique([user_email, place_id])
}

model UserReview {
  id          String   @id @default(uuid())
  user_id     String?
  place_id    String
  rating      Float
  override_price String?
  override_hours String?
  createdAt   DateTime @default(now())

  place       PlaceInfo @relation(fields: [place_id], references: [place_id])
}

model Log {
  log_id    String   @id @default(uuid())
  user_id   String
  action    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [user_id], references: [id])
}
